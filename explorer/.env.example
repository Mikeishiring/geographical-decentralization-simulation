# Required: Anthropic API key for Claude-powered exploration
ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: Anthropic model override. Defaults to a fast Sonnet model.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: API server port (default 3201)
PORT=3201

# Optional: Allowed CORS origins, comma-separated (default: localhost dev servers)
ALLOWED_ORIGINS=http://localhost:3200,http://localhost:5180

# Optional: Python executable used by the exact simulation worker.
# On Linux/Railway this should usually be python3.
PYTHON_EXECUTABLE=python3

# Optional: Absolute path to the repository root if the API server is started from a nested working directory.
SIMULATION_REPO_ROOT=/app

# Optional: Number of warm simulation workers to keep available.
SIMULATION_WORKERS=2
